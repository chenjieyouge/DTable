{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["vite/client", "node"],
    "declaration": true,
    "declarationDir": "./dist/types",
    "emitDeclarationOnly": true,
    "outDir": "./dist/types",
    "rootDir": "./src"
  },
  "include": [
    "src/lib.ts",
    "src/types/**/*",
    "src/table/**/*",
    "src/dom/**/*",
    "src/scroll/**/*",
    "src/config/**/*",
    "src/utils/**/*",
    "src/api/**/*"
  ],
  "exclude": [
    "src/main.ts",
    "src/demo.ts"
  ]
}
